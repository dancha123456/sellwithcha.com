---
---
<section class="mt-section-v grid grid-cols-1 md:grid-cols-2 gap-stack-lg">
    <!-- Benefits -->
    <div class="flex flex-col gap-stack-md bg-surface-container-low p-6 rounded-lg border border-outline-variant">
        <h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
            <svg class="w-6 h-6 text-secondary" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-1.91l-.01-.01L23 10z"/></svg>
            Why Call Us?
        </h2>
        <ul class="flex flex-col gap-4">
            <li class="flex items-start gap-3 font-body-md text-body-md text-on-surface">
                <svg class="w-5 h-5 text-secondary mt-1" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                Sell As-Is
            </li>
            <li class="flex items-start gap-3 font-body-md text-body-md text-on-surface">
                <svg class="w-5 h-5 text-secondary mt-1" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                No Repairs Upfront
            </li>
            <li class="flex items-start gap-3 font-body-md text-body-md text-on-surface">
                <svg class="w-5 h-5 text-secondary mt-1" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                We Handle the Hard Parts
            </li>
        </ul>
    </div>
    <!-- Disqualifiers -->
    <div class="flex flex-col gap-stack-md bg-error-container p-6 rounded-lg border border-error">
        <h2 class="font-headline-md text-headline-md text-error flex items-center gap-2">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L1 21h22L12 2zm0 3.99L19.53 19H4.47L12 5.99zM11 16h2v2h-2zm0-6h2v4h-2z"/></svg>
            Do NOT call if you're:
        </h2>
        <ul class="flex flex-col gap-4">
            <li class="flex items-start gap-3 font-body-md text-body-md text-on-error-container">
                <svg class="w-5 h-5 text-error mt-1" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
                Just seeing what it's worth
            </li>
            <li class="flex items-start gap-3 font-body-md text-body-md text-on-error-container">
                <svg class="w-5 h-5 text-error mt-1" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
                Looking to interview 10 buyers or compare endless offers
            </li>
            <li class="flex items-start gap-3 font-body-md text-body-md text-on-error-container">
                <svg class="w-5 h-5 text-error mt-1" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
                An agent or investor
            </li>
            <li class="flex items-start gap-3 font-body-md text-body-md text-on-error-container">
                <svg class="w-5 h-5 text-error mt-1" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
                Not the homeowner or authorized decision-maker (Inherited is okay!)
            </li>
        </ul>
    </div>
</section>
