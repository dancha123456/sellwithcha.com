---
const isHome = Astro.url.pathname === '/';
---
<header class="bg-surface-container-lowest dark:bg-primary-container text-secondary dark:text-secondary-fixed border-b border-outline-variant dark:border-outline fixed full-width top-0 w-full z-50">
    <div class="flex justify-between items-center w-full px-margin-mobile md:px-gutter max-w-container-max mx-auto h-12 md:h-16">
        <div class="flex items-center gap-1 md:gap-2">
            <div class="bg-white p-1 rounded-sm w-24 md:w-28 flex-shrink-0 flex items-center justify-center">
                <img src="/logo.webp" alt="Cash Homebuyers America Logo" class="block w-full h-auto object-contain" onerror="this.style.display='none'" />
            </div>
            <span class="text-base leading-none font-extrabold md:text-headline-md md:font-headline-md text-gray-900 ml-2 md:ml-4">Cash Homebuyers America</span>
        </div>
        <nav class="flex items-center gap-4">
            {!isHome && (
                <a class="bg-green-800 text-white px-4 py-2 rounded font-bold hover:opacity-80 transition-opacity" href="/">Home</a>
            )}
        </nav>
    </div>
</header>
