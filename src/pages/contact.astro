---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us - Cash Homebuyers America">
    <div class="max-w-4xl mx-auto p-6 text-gray-900 mt-20 mb-20 space-y-6 text-center">
        <h1 class="text-3xl font-bold mb-4">Contact Us</h1>
        
        <p class="text-lg">Have questions about selling your house?<br>Talk directly with a decision-maker.</p>
        
        <div class="bg-gray-50 p-8 rounded-lg border border-gray-200 mt-8 mb-8 inline-block text-left">
            <p class="mb-4">
                <strong>Phone:</strong> <a href="tel:8556061855" class="text-[#1E73BE] hover:underline font-bold text-xl">(855) 606-1855</a>
            </p>
            <p class="mb-4">
                <strong>Email:</strong> <a href="mailto:dan@cashhomebuyersamerica.com" class="text-[#1E73BE] hover:underline">dan@cashhomebuyersamerica.com</a>
            </p>
            <p class="mt-6 font-bold">Business Hours:</p>
            <p>Monday - Sunday<br>24/7</p>
        </div>

        <p>You may also submit your information through our <a href="/" class="text-[#1E73BE] hover:underline">website</a>, and we'll contact you regarding your property inquiry.</p>
    </div>
</Layout>
