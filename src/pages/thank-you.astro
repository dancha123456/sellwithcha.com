---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div
        class="flex-grow w-full max-w-container-max mx-auto px-margin-mobile md:px-gutter pb-section-v flex flex-col justify-center items-center text-center mt-16 md:mt-24"
    >
        <h1
            class="font-display-md text-display-md md:font-display-lg md:text-display-lg text-primary mb-6"
        >
            Thank you for leaving your information!
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface mb-4 max-w-2xl">
            Dan will call you in the next 30-60 seconds from <a
                href="tel:(855) 606-1855"
                class="text-secondary font-bold hover:underline"
                >(855) 606-1855</a
            > during business hours.
        </p>
        <p class="font-body-lg text-body-lg text-on-surface mb-12 max-w-2xl">
            If it's urgent and you can't wait, please call <a
                href="tel:(855) 606-1855"
                class="text-secondary font-bold hover:underline"
                >(855) 606-1855</a
            >.
        </p>

        <a
            class="bg-primary text-on-primary font-headline-md text-headline-md py-4 px-8 rounded-DEFAULT border-b-2 border-on-surface hover:bg-on-surface-variant transition-colors flex items-center gap-3"
            href="tel:(855) 606-1855"
        >
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"
                ><path
                    d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.03 21c.76 0 .99-.66.99-1.21v-3.42c0-.55-.45-.99-.99-.99z"
                ></path></svg
            >
            CALL NOW - (855) 606-1855
        </a>
        <a href="/" class="mt-6 inline-block text-blue-600 underline font-bold"
            >Back to Home</a
        >
    </div>
</Layout>
